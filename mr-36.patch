From ed5e87ea4f9af92996b76a0031b5e0a0070314a8 Mon Sep 17 00:00:00 2001
From: bbhtt <bbhtt.zn0i8@slmail.me>
Date: Sun, 23 Jun 2024 08:36:43 +0530
Subject: [PATCH 1/2] Add launchable to metainfo

See https://invent.kde.org/teams/flathub/issues/-/issues/28
---
 org.kde.minuet.metainfo.xml | 1 +
 1 file changed, 1 insertion(+)

diff --git a/org.kde.minuet.metainfo.xml b/org.kde.minuet.metainfo.xml
index 82e9882..f4c5d72 100644
--- a/org.kde.minuet.metainfo.xml
+++ b/org.kde.minuet.metainfo.xml
@@ -3,6 +3,7 @@
   <id>org.kde.minuet.desktop</id>
   <metadata_license>CC0-1.0</metadata_license>
   <project_license>GPL-2.0+</project_license>
+  <launchable type="desktop-id">org.kde.minuet.desktop</launchable>
   <name>Minuet</name>
   <name xml:lang="ar">منويت</name>
   <name xml:lang="ca">Minuet</name>
-- 
