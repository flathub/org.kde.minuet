From cacc1f05cc6b2b99b5e6c821f481e213293ecf16 Mon Sep 17 00:00:00 2001
From: Boudhayan Bhattacharya <bbhtt.zn0i8@slmail.me>
Date: Sun, 23 Jun 2024 08:36:47 +0530
Subject: [PATCH 2/2] Install only a 128px SVG to the scalable folder

16px, 22px, 32px, 48px and 64px SVGs are being installed to icon folders
reserved for PNG files. Keep the largest 128px SVG and delete the rest.
Also rename it so that it gets installed under scalable folder
---
 src/app/CMakeLists.txt                        |    7 +-
 src/app/icons/16-apps-minuet.svg              |  975 ---------------
 src/app/icons/22-apps-minuet.svg              |  923 --------------
 src/app/icons/32-apps-minuet.svg              | 1097 -----------------
 src/app/icons/48-apps-minuet.svg              |  622 ----------
 src/app/icons/64-apps-minuet.svg              |  627 ----------
 ...128-apps-minuet.svg => sc-apps-minuet.svg} |    0
 7 files changed, 1 insertion(+), 4250 deletions(-)
 delete mode 100644 src/app/icons/16-apps-minuet.svg
 delete mode 100644 src/app/icons/22-apps-minuet.svg
 delete mode 100644 src/app/icons/32-apps-minuet.svg
 delete mode 100644 src/app/icons/48-apps-minuet.svg
 delete mode 100644 src/app/icons/64-apps-minuet.svg
 rename src/app/icons/{128-apps-minuet.svg => sc-apps-minuet.svg} (100%)

